# Environment & secrets
.env
.env.*
!.env.example

# Local seed / credentials (use register.example.json)
register.json

# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]

# Logs
*.log
logs/

# Playwright MCP local snapshots
.playwright-mcp/

# Local Docker-mounted data (PostgreSQL/MinIO)
